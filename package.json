{
  "name": "design-system",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:tokens": "pnpm --filter @yeoooonn/ds-tokens build",
    "build:web": "pnpm --filter @yeoooonn/ds-web build",
    "build:app": "pnpm --filter @yeoooonn/ds-app build",
    "dev:tokens": "pnpm --filter @yeoooonn/ds-tokens dev",
    "dev:web": "pnpm --filter @yeoooonn/ds-web dev",
    "storybook": "pnpm --filter @yeoooonn/ds-web storybook",
    "demo:web": "pnpm --filter @ds/demo-web dev",
    "demo:app": "pnpm --filter @ds/demo-app web"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
